# Local development environment variables
# DO NOT commit real keys to git
# The harness injects real values at evaluation time

FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
ALLOWED_MODELS=accounts/fireworks/models/llama-v3p1-8b-instruct,accounts/fireworks/models/llama-v3p1-70b-instruct

# Optional overrides for local testing
# INPUT_PATH=./input/tasks.json
# OUTPUT_PATH=./output/results.json
# LOCAL_MODEL=qwen2.5:1.5b
# LOCAL_TIMEOUT_SEC=45
# DISABLE_LOCAL_MODEL=false
